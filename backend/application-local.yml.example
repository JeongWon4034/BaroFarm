# 이 파일을 복사해 backend/application-local.yml 로 만들고 실제 키를 채우세요.
# application-local.yml 은 .gitignore 되어 있어 커밋되지 않습니다. (절대 커밋 금지)
# jar 실행 위치(backend/) 기준으로 자동 로드됩니다 (spring.config.import).

ai:
  base-url: <GMS 엔드포인트, 예: https://.../v1>   # 팀 안내 엔드포인트로 교체
  api-key: <GMS_KEY>                               # 팀 키
  model: gpt-4o-mini

# 가락 시세 API (추천가 고도화용, 선택)
garak:
  api:
    passwd: <GARAK_API_KEY>
