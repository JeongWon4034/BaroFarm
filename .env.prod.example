# BaroFarm v1 운영 환경변수 — VM에서 `cp .env.prod.example .env` 후 값 채우기.
# docker-compose.prod.yml 이 자동으로 .env 를 읽음. 절대 커밋 금지(.env 는 gitignore됨).

# 도메인 (DuckDNS 무료 서브도메인). Caddy가 이 주소로 자동 HTTPS 발급.
# 로컬 HTTP 테스트만 할 땐 DOMAIN=:80 으로.
DOMAIN=baro-farm.duckdns.org

# MySQL root 비밀번호 (운영에선 1234 말고 강한 값으로)
MYSQL_ROOT_PASSWORD=change-me-strong

# JWT 서명키 — 반드시 길고 랜덤하게 (예: openssl rand -base64 48)
JWT_SECRET=change-me-very-long-random-secret

# 생성형 AI (GMS). VM에서 gms.ssafy.io 도달 안 되면 비워두면 규칙기반 폴백.
AI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_PRICE_MODEL=gpt-4o

# KAMIS 농수산물 시세
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# 네이버 쇼핑 검색 (경쟁 소매가)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
