# BaroFarm 도커 환경변수 템플릿.
#   cp .env.example .env  후 실제 키 입력 (.env 는 gitignore — 절대 커밋 금지)
# 비워둬도 앱은 정상 기동하며, 해당 AI/시세 기능만 비활성화됩니다.
# ⚠️ 이 파일(.env.example)에는 실제 키를 절대 넣지 마세요 — git에 추적됩니다.

# ── SSAFY GMS (생성형 AI, OpenAI 호환 프록시) ──────────────
AI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── KAMIS 농수산물 시세 API (추천가 고도화) ────────────────
KAMIS_CERT_KEY=
KAMIS_CERT_ID=

# ── JWT 서명 시크릿 (운영 배포 시 반드시 교체) ─────────────
JWT_SECRET=freshgrowth-dev-secret-key-change-me-in-production-0123456789ab
