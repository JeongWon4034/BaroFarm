# BaroFarm v1 — Caddy 한 개가 [정적 프론트 서빙 + API/업로드 프록시 + 자동 HTTPS]를 담당.
# DOMAIN 환경변수로 사이트 주소 주입(예: baro-farm.duckdns.org). 로컬 HTTP 테스트는 DOMAIN=:80.
{$DOMAIN} {
	encode gzip zstd

	# 백엔드(Spring)로 — REST API + 판매자 업로드 이미지
	@backend path /api/* /uploads/*
	reverse_proxy @backend backend:8080

	# 그 외 전부 SPA 정적 파일 (빌드된 dist; /seed-images 도 여기 포함).
	# 라우트 못 찾으면 index.html로 폴백(Vue Router history 모드).
	root * /srv
	try_files {path} /index.html
	file_server
}
